{
  "uid": "accsaber-latency-attribution",
  "title": "AccSaber - Latency Attribution",
  "tags": ["accsaber"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Probe duration by target",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "accsaber-prometheus" },
      "targets": [
        { "expr": "probe_duration_seconds{target_kind=\"internal\"}", "legendFormat": "internal (JVM only)" },
        { "expr": "probe_duration_seconds{target_kind=\"api_via_cf\"}", "legendFormat": "api.accsaber.com (CF + JVM)" },
        { "expr": "probe_duration_seconds{target_kind=\"frontend_zone_via_cf\"}", "legendFormat": "accsaber.com (CF + JVM)" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Cloudflare overhead (probe - JVM time)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "accsaber-prometheus" },
      "targets": [
        { "expr": "probe_duration_seconds{target_kind=\"api_via_cf\"} - on() probe_duration_seconds{target_kind=\"internal\"}", "legendFormat": "api zone overhead" },
        { "expr": "probe_duration_seconds{target_kind=\"frontend_zone_via_cf\"} - on() probe_duration_seconds{target_kind=\"internal\"}", "legendFormat": "frontend zone overhead" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Phase durations: api.accsaber.com",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "accsaber-prometheus" },
      "targets": [
        { "expr": "probe_http_duration_seconds{target_kind=\"api_via_cf\",phase=\"resolve\"}", "legendFormat": "DNS" },
        { "expr": "probe_http_duration_seconds{target_kind=\"api_via_cf\",phase=\"connect\"}", "legendFormat": "Connect" },
        { "expr": "probe_http_duration_seconds{target_kind=\"api_via_cf\",phase=\"tls\"}", "legendFormat": "TLS" },
        { "expr": "probe_http_duration_seconds{target_kind=\"api_via_cf\",phase=\"processing\"}", "legendFormat": "Processing (TTFB)" },
        { "expr": "probe_http_duration_seconds{target_kind=\"api_via_cf\",phase=\"transfer\"}", "legendFormat": "Transfer" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Phase durations: accsaber.com",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "accsaber-prometheus" },
      "targets": [
        { "expr": "probe_http_duration_seconds{target_kind=\"frontend_zone_via_cf\",phase=\"resolve\"}", "legendFormat": "DNS" },
        { "expr": "probe_http_duration_seconds{target_kind=\"frontend_zone_via_cf\",phase=\"connect\"}", "legendFormat": "Connect" },
        { "expr": "probe_http_duration_seconds{target_kind=\"frontend_zone_via_cf\",phase=\"tls\"}", "legendFormat": "TLS" },
        { "expr": "probe_http_duration_seconds{target_kind=\"frontend_zone_via_cf\",phase=\"processing\"}", "legendFormat": "Processing (TTFB)" },
        { "expr": "probe_http_duration_seconds{target_kind=\"frontend_zone_via_cf\",phase=\"transfer\"}", "legendFormat": "Transfer" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Backend HTTP request latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "accsaber-prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Probe success rate (last 5 min)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "accsaber-prometheus" },
      "targets": [
        { "expr": "avg by (target_kind) (avg_over_time(probe_success[5m]))", "legendFormat": "{{target_kind}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      }
    },
    {
      "title": "Probe SSL cert days until expiry",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "accsaber-prometheus" },
      "targets": [
        { "expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400", "legendFormat": "{{target_kind}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "d" }
      }
    },
    {
      "title": "Probe HTTP version negotiated",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "accsaber-prometheus" },
      "targets": [
        { "expr": "probe_http_version{target_kind=\"api_via_cf\"}", "legendFormat": "api zone" },
        { "expr": "probe_http_version{target_kind=\"frontend_zone_via_cf\"}", "legendFormat": "frontend zone" }
      ]
    }
  ]
}
